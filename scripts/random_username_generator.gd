static func generate_username(separator: String = "", rng: RandomNumberGenerator = null) -> String:
	var local_rng := rng
	if local_rng == null:
		local_rng = RandomNumberGenerator.new()
		local_rng.randomize()

	var adjective: String = ADJECTIVES[local_rng.randi_range(0, ADJECTIVES.size() - 1)]
	var noun: String = NOUNS[local_rng.randi_range(0, NOUNS.size() - 1)]
	return "%s%s%s" % [adjective, separator, noun]
